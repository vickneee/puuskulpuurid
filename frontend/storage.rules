rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // Public read access for gallery images
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

